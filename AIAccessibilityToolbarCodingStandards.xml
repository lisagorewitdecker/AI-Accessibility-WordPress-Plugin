<?xml version="1.0"?>
<ruleset name="AI Accessibility Toolbar">
    <description>Coding standard for the AI Accessibility Toolbar plugin.</description>

    <file>.</file>

    <!-- Exclusions -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/assets/js/*</exclude-pattern>
    <exclude-pattern>*/assets/css/*</exclude-pattern>

    <!-- Enforce WordPress coding style + escaping rules -->
    <rule ref="WordPress">
        <!-- Allow modern short arrays if you prefer them; delete this to keep long arrays. -->
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>
        <!-- Plugin files use PascalCase filenames; renaming would break the plugin loader. -->
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <!-- WordPress themes/plugins commonly embed PHP inside HTML templates. -->
        <exclude name="Squiz.PHP.EmbeddedPhp.ContentAfterOpen"/>
        <exclude name="Squiz.PHP.EmbeddedPhp.ContentBeforeEnd"/>
    </rule>

    <!-- Text-domain check -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="ai-accessibility-toolbar"/>
            </property>
        </properties>
    </rule>

    <!-- PHP compatibility (matches the plugin's Requires PHP: 7.4 header) -->
    <config name="testVersion" value="7.4-"/>
    <rule ref="PHPCompatibilityWP"/>
</ruleset>
