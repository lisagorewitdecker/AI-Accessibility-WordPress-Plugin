{
    "name": "lisamgorewitdecker/ai-accessibility-toolbar",
    "description": "A Material Design accessibility toolbar with an AI-powered \"Summarize this page\" button backed securely by the Gemini API.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress",
        "wordpress-plugin",
        "accessibility",
        "a11y",
        "gemini",
        "ai",
        "summarize"
    ],
    "authors": [
        {
            "name": "Lisa M Gorewit-Decker",
            "role": "Developer"
        }
    ],
    "homepage": "https://wordpress.org/plugins/ai-accessibility-toolbar/",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=7.4",
        "composer/installers": "^2.0"
    },
    "require-dev": {
        "php-stubs/wordpress-stubs": "^6.6",
        "php-stubs/wp-cli-stubs": "^2.10",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "lint": "phpcs --standard=AIAccessibilityToolbarCodingStandards.xml",
        "lint:fix": "phpcbf --standard=AIAccessibilityToolbarCodingStandards.xml",
        "lint:compat": "phpcs --standard=AIAccessibilityToolbarCodingStandards.xml --runtime-set testVersion 7.4- ."
    },
    "extra": {
        "installer-name": "ai-accessibility-toolbar"
    }
}
